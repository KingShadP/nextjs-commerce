# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ADMIN_PASSCODE: The secure passcode used to validate edits inside the administrative CMS portal.
# Defaults to "kingshadp_admin" if not specified.
ADMIN_PASSCODE="kingshadp_admin"

# ─── Shopify Integration ────────────────────────────────────────────────────
# SHOPIFY_DOMAIN: Your store's myshopify.com domain (e.g. my-store.myshopify.com)
# Custom domains also work (e.g. shop.kingshadp.com).
SHOPIFY_DOMAIN="my-store.myshopify.com"

# SHOPIFY_STOREFRONT_ACCESS_TOKEN: Public Storefront API access token.
# Generate in Shopify Admin → Settings → Apps → Develop apps → Storefront API.
# This token is only used SERVER-SIDE and is never exposed to the browser.
SHOPIFY_STOREFRONT_ACCESS_TOKEN="shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
