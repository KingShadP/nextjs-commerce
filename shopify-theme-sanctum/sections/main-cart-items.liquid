{%- comment -%}
  Standard fallback cart details page
{%- endcomment -%}
<section class="max-w-3xl mx-auto px-6 py-24 space-y-12">
  <div class="border-b border-white/5 pb-6 text-center">
    <span class="font-sans text-[8px] text-skims-accent tracking-[3px] uppercase">Order Registry Ledger</span>
    <h1 class="font-serif text-3xl text-white tracking-wide uppercase font-light mt-1">Shopping Cart</h1>
  </div>

  <div class="glass-panel rounded-3xl p-6 sm:p-12 space-y-8">
    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" class="space-y-6">
        {% for item in cart.items %}
          <div class="flex items-center gap-6 border-b border-white/5 pb-6">
            <img src="{{ item.image | image_url: width: 150 }}" alt="{{ item.title | escape }}" class="w-16 h-20 object-cover border border-white/10">
            <div class="flex-grow space-y-1 text-left">
              <h3 class="font-serif text-sm text-white uppercase font-light">{{ item.product.title }}</h3>
              <p class="font-sans text-[9px] text-skims-accent tracking-[1.5px] uppercase">{{ item.variant.title }}</p>
              <p class="font-sans text-[10px] text-skims-sand/60 font-bold">{{ item.final_line_price | money }}</p>
            </div>
            <div>
              <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="text-white/40 hover:text-white text-[9px] font-sans tracking-[1px] uppercase">Remove</a>
            </div>
          </div>
        {% endfor %}

        <div class="flex justify-between items-center font-sans text-xs tracking-[2px] uppercase pt-4">
          <span>Subtotal</span>
          <span class="text-white font-bold">{{ cart.total_price | money }}</span>
        </div>

        <div class="pt-6">
          <button type="submit" name="checkout" class="w-full py-4.5 bg-skims-accent hover:bg-white text-black font-sans font-bold text-[9px] tracking-[3px] uppercase transition-all duration-300 rounded-full cursor-pointer">
            Proceed to Checkout
          </button>
        </div>
      </form>
    {% else %}
      <div class="text-center py-12">
        <p class="font-sans text-[10px] text-skims-sand/40 tracking-[2px] uppercase">Bag is currently vacant</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
