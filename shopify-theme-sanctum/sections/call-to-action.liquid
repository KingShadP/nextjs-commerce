<!-- Customizable call-to-action section -->
<section class="cta-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="cta-content">
    {% if section.settings.eyebrow %}
      <span class="cta-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    <h2 class="cta-heading">{{ section.settings.heading }}</h2>

    {% if section.settings.description %}
      <p class="cta-description">{{ section.settings.description }}</p>
    {% endif %}

    <div class="cta-buttons">
      {% if section.settings.primary_button_text and section.settings.primary_button_url %}
        <a href="{{ section.settings.primary_button_url }}" class="button button--primary">
          {{ section.settings.primary_button_text }}
        </a>
      {% endif %}

      {% if section.settings.secondary_button_text and section.settings.secondary_button_url %}
        <a href="{{ section.settings.secondary_button_url }}" class="button button--ghost">
          {{ section.settings.secondary_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Limited Time"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Don't Miss Out"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Take action now to get exclusive access"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#090807"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5f3ef"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding (rem)",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Call to Action"
    }
  ]
}
{% endschema %}

<style>
  .cta-section {
    padding: {{ section.settings.padding }}rem 1.5rem;
    text-align: {{ section.settings.text_alignment }};
  }

  .cta-content {
    max-width: 1000px;
    margin: 0 auto;
  }

  .cta-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #c5a880;
    margin-bottom: 0.75rem;
  }

  .cta-heading {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: {{ section.settings.text_color }};
    line-height: 1.1;
  }

  .cta-description {
    margin-bottom: 1.75rem;
    font-size: 1.1rem;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    opacity: 0.85;
    max-width: 600px;
    {% if section.settings.text_alignment == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    {% if section.settings.text_alignment == 'center' %}justify-content: center;{% elif section.settings.text_alignment == 'right' %}justify-content: flex-end;{% endif %}
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .cta-buttons {
      flex-direction: column;
      align-items: {% if section.settings.text_alignment == 'center' %}center{% elif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    }
  }
</style>
