{%- comment -%}
  Search Results
{%- endcomment -%}

<section class="max-w-7xl mx-auto px-6 py-12 md:py-24 space-y-12 select-none">
  <div class="border-b border-white/5 pb-6 text-left">
    <span class="font-sans text-[8px] text-skims-accent tracking-[3px] uppercase">Search Registry Results</span>
    <h1 class="font-serif text-3.5xl md:text-5xl text-white tracking-wide uppercase font-light mt-1">
      Query: "{{ search.terms }}"
    </h1>
  </div>

  {% if search.performed %}
    {% if search.results_count > 0 %}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            <div class="h-full">
              {% render 'product-card', product: item %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="py-24 text-center">
        <p class="font-sans text-[10px] text-skims-sand/40 tracking-[2px] uppercase">No results found in database records</p>
      </div>
    {% endif %}
  {% endif %}
</section>

{% schema %}
{
  "name": "Search Grid",
  "settings": []
}
{% endschema %}
