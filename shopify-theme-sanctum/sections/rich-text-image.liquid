<!-- Rich text and image section for flexible layouts -->
<section class="rich-text-section">
  <div class="rich-text-container">
    {% if section.settings.image %}
      <div
        class="rich-text-image"
        style="background-image: url('{{ section.settings.image | img_url: '600x600' }}')"
      ></div>
    {% endif %}
    <div class="rich-text-content">
      {% if section.settings.heading %}
        <h2 class="rich-text-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text %}
        <div class="rich-text-body">{{ section.settings.text }}</div>
      {% endif %}
      {% if section.settings.button_text and section.settings.button_url %}
        <a href="{{ section.settings.button_url }}" class="button button--{{ section.settings.button_style }}">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text + Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text content",
      "default": "<p>Add your text content here</p>"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "ghost", "label": "Ghost" }
      ],
      "default": "primary"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image-left", "label": "Image Left" },
        { "value": "image-right", "label": "Image Right" }
      ],
      "default": "image-left"
    }
  ],
  "presets": [
    {
      "name": "Rich Text + Image",
      "settings": {
        "heading": "New Section"
      }
    }
  ]
}
{% endschema %}

<style>
  .rich-text-section {
    padding: 4rem 1.5rem;
  }

  .rich-text-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
  }

  .rich-text-image {
    aspect-ratio: 1;
    background-size: cover;
    background-position: center;
    border-radius: 0.8rem;
  }

  .rich-text-heading {
    margin: 0 0 1rem;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
  }

  .rich-text-body {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .rich-text-container {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
